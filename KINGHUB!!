        local function CreateHeatParticle(container)
            local width = container.AbsoluteSize.X
            local height = container.AbsoluteSize.Y
            if width == 0 or height == 0 then return end
            
            local size = math.random(3, 12)
            local x = math.random(10, width - 10)
            local y = math.random(height * 0.2, height * 0.9)
            
            local particle = Instance.new("Frame")
            particle.Size = UDim2.new(0, size, 0, size)
            particle.Position = UDim2.new(0, x, 0, y)
            particle.BackgroundColor3 = Color3.fromRGB(200 + math.random(0, 55), 50 + math.random(0, 100), 100 + math.random(0, 80))
            particle.BackgroundTransparency = 0.3 + math.random() * 0.3
            particle.BorderSizePixel = 0
            particle.ZIndex = 5
            particle.Parent = container
            
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(1, 0)
            corner.Parent = particle
            
            local glow = Instance.new("Frame")
            glow.Size = UDim2.new(1.5, 0, 1.5, 0)
            glow.Position = UDim2.new(-0.25, 0, -0.25, 0)
            glow.BackgroundColor3 = Color3.fromRGB(255, 100, 150)
            glow.BackgroundTransparency = 0.85
            glow.BorderSizePixel = 0
            glow.ZIndex = 4
            glow.Parent = particle
            local glowCorner = Instance.new("UICorner")
            glowCorner.CornerRadius = UDim.new(1, 0)
            glowCorner.Parent = glow
            
            table.insert(heatParticles, particle)
            
            -- Smooth floating motion with sine wave
            local startX = x
            local startY = y
            local driftX = math.random(-30, 30)
            local driftY = -math.random(20, 60)
            local duration = math.random(1.5, 3.5)
            local phase = math.random() * math.pi * 2
            local amplitude = math.random(5, 20)
            
            -- Fade in
            TweenService:Create(particle, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {
                BackgroundTransparency = 0.1
            }):Play()
            
            -- Animate the particle with wave motion
            local startTime = tick()
            local endTime = startTime + duration
            local connection
            connection = RunService.RenderStepped:Connect(function()
                if not particle.Parent then
                    connection:Disconnect()
                    return
                end
                local elapsed = tick() - startTime
                local progress = elapsed / duration
                
                if progress >= 1 then
                    connection:Disconnect()
                    TweenService:Create(particle, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, size * 0.2, 0, size * 0.2)
                    }):Play()
                    task.delay(0.5, function()
                        if particle and particle.Parent then particle:Destroy() end
                        for i, p in ipairs(heatParticles) do
                            if p == particle then table.remove(heatParticles, i) break end
                        end
                    end)
                    return
                end
                
                -- Wave-like motion
                local waveX = math.sin(progress * math.pi * 2 + phase) * amplitude * (1 - progress)
                local currentX = startX + driftX * progress + waveX
                local currentY = startY + driftY * progress - math.sin(progress * math.pi) * 20
                
                particle.Position = UDim2.new(0, currentX, 0, currentY)
                
                -- Size pulsing
                local pulseSize = size * (0.8 + 0.4 * math.sin(progress * math.pi * 4))
                particle.Size = UDim2.new(0, pulseSize, 0, pulseSize)
                
                -- Color shift from blue to red to white
                local hue = 0.9 - progress * 0.3
                local saturation = 0.8 + 0.2 * math.sin(progress * math.pi)
                local value = 0.8 + 0.2 * math.sin(progress * math.pi * 0.5)
                particle.BackgroundColor3 = Color3.fromHSV(hue, saturation, value)
                
                -- Transparency
                local trans = 0.1 + 0.6 * progress * progress
                particle.BackgroundTransparency = trans
                glow.BackgroundTransparency = 0.7 + 0.3 * progress
            end)
            
            -- Cleanup if not already handled
            task.delay(duration + 1, function()
                if particle and particle.Parent then particle:Destroy() end
                for i, p in ipairs(heatParticles) do
                    if p == particle then table.remove(heatParticles, i) break end
                end
            end)
        end

