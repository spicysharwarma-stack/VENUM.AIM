-- ANIMATION HELPERS
local function SetLogoAlpha(a)
    for _, f in ipairs(allLogoFrames) do
        if f:IsA("TextLabel") then f.TextTransparency = a else f.BackgroundTransparency = a end
    end
    titleLabel.TextTransparency = a
    titleStroke.Transparency = a
    subLabel.TextTransparency = math.min(a+0.1,1)
end
local function TweenLogoAlpha(targetA, dur, delay_, sty)
    sty = sty or Enum.EasingStyle.Quad
    for _, f in ipairs(allLogoFrames) do
        if f:IsA("TextLabel") then Tween(f, {TextTransparency = targetA}, dur, sty, nil, delay_)
        else Tween(f, {BackgroundTransparency = targetA}, dur, sty, nil, delay_) end
    end
    Tween(titleLabel, {TextTransparency = targetA}, dur, sty, nil, delay_)
    Tween(titleStroke, {Transparency = targetA}, dur, sty, nil, delay_)
    Tween(subLabel, {TextTransparency = math.min(targetA+0.1,1)}, dur, sty, nil, delay_)
end
local function TweenShafts(targetA, dur, delay_)
    for i,s in ipairs(shaftFrames) do
        if shaftDefs[i] then Tween(s, {BackgroundTransparency = targetA}, dur, Enum.EasingStyle.Sine, nil, delay_) end
    end
    Tween(ambientGlow, {BackgroundTransparency = targetA+0.05}, dur, nil, nil, delay_)
end

-- SPECK ANIMATION
local specksActive = true
local function AnimateSpeck(speck)
    if not speck or not speck.Parent then return end
    speck.Position = UDim2.new(Rand(0.08,0.92),0, Rand(0.3,0.9),0)
    speck.BackgroundTransparency = 1
    task.delay(Rand(0,0.5), function()
        if not speck.Parent or not specksActive then return end
        local startX, startY = speck.Position.X.Scale, speck.Position.Y.Scale
        local driftX, driftY = (math.random()-0.5)*0.08, -Rand(0.05,0.14)
        local life = Rand(1.4,3.2)
        Tween(speck, {BackgroundTransparency = Rand(0.15,0.55)}, life*0.3, Enum.EasingStyle.Sine)
        Tween(speck, {Position = UDim2.new(startX+driftX,0, startY+driftY,0), BackgroundTransparency = 1}, life, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
        task.delay(life+0.1, function() if specksActive then AnimateSpeck(speck) end end)
    end)
end

