            Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((current-min)/(max-min),0,1,0)
            fill.BackgroundColor3 = theme.SliderFill
            fill.BorderSizePixel = 0
            fill.ZIndex = 12
            fill.Parent = track
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
            local thumb = Instance.new("Frame")
            thumb.Size = UDim2.new(0,12,0,12)
            thumb.Position = UDim2.new((current-min)/(max-min),-6,0.5,-6)
            thumb.BackgroundColor3 = Color3.new(1,1,1)
            thumb.BorderSizePixel = 0
            thumb.ZIndex = 13
            thumb.Parent = track
            Instance.new("UICorner", thumb).CornerRadius = UDim.new(1,0)
            local dragging = false
            local function updateValue(value)
                local clamped = math.clamp(value, min, max)
                current = clamped
                label.Text = text .. ": " .. string.format("%.3f", clamped)
                fill.Size = UDim2.new((clamped-min)/(max-min),0,1,0)
                thumb.Position = UDim2.new((clamped-min)/(max-min),-6,0.5,-6)
                pcall(callback, clamped)
            end
            local function onInput(input)
                if dragging then
                    local relX = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                    updateValue(min + relX * (max - min))
                end
            end
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    onInput(input)
                end
            end)
            track.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    onInput(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            return {update = updateValue}
        end

