            local glow = Instance.new("Frame")
            glow.Size = UDim2.new(2, 0, 2, 0)
            glow.Position = UDim2.new(-0.5, 0, -0.5, 0)
            glow.BackgroundColor3 = Color3.fromRGB(50, 100, 255)
            glow.BackgroundTransparency = 0.85
            glow.BorderSizePixel = 0
            glow.ZIndex = 998
            glow.Parent = particle
            local glowCorner = Instance.new("UICorner")
            glowCorner.CornerRadius = UDim.new(1, 0)
            glowCorner.Parent = glow
            
            table.insert(auraParticles, particle)
            
            -- Animate the particle orbiting around torso
            local startTime = tick()
            local duration = math.random(1.5, 3.5)
            local startX = x
            local startZ = z
            local startY = y
            local orbitSpeed = math.random(2, 5)
            local floatSpeed = math.random(1, 3)
            local driftY = (math.random() - 0.5) * 2
            
            local connection
            connection = RunService.RenderStepped:Connect(function()
                if not particle.Parent or not torso.Parent or not auraActive then
                    connection:Disconnect()
                    if particle and particle.Parent then particle:Destroy() end
                    for i, p in ipairs(auraParticles) do
                        if p == particle then table.remove(auraParticles, i) break end
                    end
                    return
                end
                
                local elapsed = tick() - startTime
                local progress = elapsed / duration
                
                if progress >= 1 then
                    connection:Disconnect()
                    TweenService:Create(particle, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, 0, 0, 0)
                    }):Play()
                    task.delay(0.5, function()
                        if particle and particle.Parent then particle:Destroy() end
                        for i, p in ipairs(auraParticles) do
                            if p == particle then table.remove(auraParticles, i) break end
                        end
                    end)
                    return
                end
                
                -- Orbital motion with sine wave floating
                local angle = elapsed * orbitSpeed + (math.random() - 0.5) * 0.5
                local radius = 2 + 0.5 * math.sin(elapsed * floatSpeed)
                local currentX = startX + math.cos(angle) * radius
                local currentZ = startZ + math.sin(angle) * radius
                local currentY = startY + math.sin(elapsed * floatSpeed * 0.7) * 1.2 + driftY * progress
                
                -- Size pulsing
                local pulseSize = size * (0.7 + 0.4 * math.sin(elapsed * 3 + angle))
                particle.Size = UDim2.new(0, pulseSize, 0, pulseSize)
                
                -- Color shift: blue to light blue to white
                local hue = 0.6 + 0.05 * math.sin(elapsed * 0.5)
                local saturation = 0.7 + 0.3 * math.sin(elapsed * 0.3)
                local value = 0.8 + 0.2 * math.sin(elapsed * 0.7)
                particle.BackgroundColor3 = Color3.fromHSV(hue, saturation, value)
                
                -- Transparency pulse
                local trans = 0.1 + 0.5 * math.sin(elapsed * 1.5 + angle) * 0.5 + 0.5
                particle.BackgroundTransparency = trans * 0.7 + 0.2
                
                -- Update position relative to torso
                local torsoPos = torso.Position
                particle.Position = UDim2.new(0, torsoPos.X + currentX * 3, 0, torsoPos.Y + currentY * 3)
                
                -- Glow effect
                glow.BackgroundTransparency = 0.6 + 0.3 * math.sin(elapsed * 2)
            end)
            
            -- Cleanup
            task.delay(duration + 1, function()
                if particle and particle.Parent then particle:Destroy() end
                for i, p in ipairs(auraParticles) do
                    if p == particle then table.remove(auraParticles, i) break end
                end
            end)
        end

