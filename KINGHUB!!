        local function getExecutorFolder()
            local execPath = nil
            if syn and syn.get_executordirectory then
                execPath = syn.get_executordirectory()
            elseif getexecutordirectory then
                execPath = getexecutordirectory()
            elseif fs and fs.getExecutablePath then
                execPath = fs.getExecutablePath():match("(.+)[\\/]")
            end
            if execPath then
                return execPath .. "/CrownHub/"
            else
                return "CrownHub/"
            end
        end

