        local function GenerateLightningBolt()
            local containerWidth = MainContainer.AbsoluteSize.X
            local containerHeight = MainContainer.AbsoluteSize.Y
            if containerWidth == 0 or containerHeight == 0 then return end

            local startX = math.random(20, containerWidth - 20)
            local startY = math.random(20, containerHeight - 20)
            local segments = math.random(5, 10)
            local currentX, currentY = startX, startY

            for i = 1, segments do
                local nextX = math.clamp(currentX + math.random(-40, 40), 10, containerWidth - 10)
                local nextY = math.clamp(currentY + math.random(-35, 35), 10, containerHeight - 10)
                local dx = nextX - currentX
                local dy = nextY - currentY
                local length = math.sqrt(dx*dx + dy*dy)
                local angle = math.deg(math.atan2(dy, dx))
                local thickness = math.random(3, 6)
                CreateLightningStrike(currentX, currentY, angle, length, thickness, Color3.fromRGB(180,220,255))

                if math.random() > 0.7 then
                    local branchAngle = angle + math.random(-50, 50)
                    local branchLen = length * math.random(40, 80)/100
                    local branchX = math.clamp(currentX + dx * 0.6, 10, containerWidth - 10)
                    local branchY = math.clamp(currentY + dy * 0.6, 10, containerHeight - 10)
                    CreateLightningStrike(branchX, branchY, branchAngle, branchLen, thickness-1, Color3.fromRGB(150,200,255))
                end
                currentX, currentY = nextX, nextY
            end
        end

