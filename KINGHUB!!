        local originalCollisionStates = {}
        local function ToggleCollision()
            if not selectedcar then return false end
            if not collisionDisabled then
                local bodyFolder = selectedcar:FindFirstChild("Body")
                if bodyFolder then
                    for _, v in pairs(bodyFolder:GetDescendants()) do
                        if v:IsA("BasePart") then
                            originalCollisionStates[v] = v.CanCollide
                            v.CanCollide = false
                        end
                    end
                    collisionDisabled = true
                    return true
                else
                    return false
                end
            else
                for part, canCollide in pairs(originalCollisionStates) do
                    if part and part.Parent then
                        part.CanCollide = canCollide
                    end
                end
                originalCollisionStates = {}
                collisionDisabled = false
                return false
            end
        end

        local originalFrictions = {}
        local function ModifyRearWheels()
            if not selectedcar then return false end
            if not rearWheelModified then
                for _, part in pairs(selectedcar:GetDescendants()) do
                    if part:IsA("BasePart") then
                        local partName = part.Name:lower()
                        if partName:find("rear") or partName:find("back") or partName:find("rwd") then
                            originalFrictions[part] = {
                                Friction = part.Friction,
                                FrictionWeight = part.FrictionWeight
                            }
                            part.Friction = 0.2
                            part.FrictionWeight = 54
                        end
                    end
                end
                rearWheelModified = true
            else
                for part, props in pairs(originalFrictions) do
                    if part and part.Parent then
                        part.Friction = props.Friction
                        part.FrictionWeight = props.FrictionWeight
                    end
                end
                originalFrictions = {}
                rearWheelModified = false
            end
            return rearWheelModified
        end

        local function ModifyWheelHeight(wheelType, direction)
            if not selectedcar then return end
            local wheelNames = {
                ["Front"] = {
                    "front", "fw", "lf", "rf", "fl", "fr",
                    "frontwheel", "front wheel", "front tire",
                    "frontaxle", "front axle", "lfront", "rfront"
                },
                ["Rear"] = {
                    "rear", "back", "rw", "lrear", "rrear",
                    "rearwheel", "rear wheel", "rear tire",
                    "rearaxle", "rear axle", "rwd"
                }
            }
            local names = wheelNames[wheelType]
            if not names then return end
            for _, part in pairs(selectedcar:GetDescendants()) do
                if part:IsA("BasePart") then
                    local partName = part.Name:lower()
                    local parentName = part.Parent and part.Parent.Name:lower() or ""
                    local isMatch = false
                    for _, name in ipairs(names) do
                        if partName:find(name) then
                            isMatch = true
                            break
                        end
                    end
                    if not isMatch then
                        if wheelType == "Front" then
                            if parentName == "lw" or parentName == "rw" then
                                isMatch = true
                            end
                        elseif wheelType == "Rear" then
                            if parentName == "rwd" then
                                isMatch = true
                            elseif parentName == "body" and (partName == "ml" or partName == "mr") then
                                isMatch = true
                            end
                        end
                    end
                    if isMatch then
                        part.Position = part.Position + Vector3.new(0, direction * wheelIncrement, 0)
                    end
                end
            end
        end

        local function ModifyAllWheels(direction)
            if not selectedcar then return end
