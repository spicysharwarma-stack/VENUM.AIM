local function MakeSpike(cx_off, cy_off, sw, sh, lean, zIdx)
    local holder = NewFrame(Gui, zIdx)
    local holderW, holderH = sw*3.2, sh*1.25
    holder.Size = UDim2.new(0, holderW, 0, holderH)
    holder.Position = UDim2.new(0.5, cx_off - holderW/2, 0.5, cy_off - holderH + 8)

    local lf = tag(NewFrame(holder, zIdx))
    lf.BackgroundColor3 = COL.goldDark
    lf.Size = UDim2.new(0, sw*0.68, 0, sh*1.08)
    lf.AnchorPoint = Vector2.new(1,1)
    lf.Position = UDim2.new(0.5, sw*0.10, 1, 0)
    lf.Rotation = lean - 11

    local cf = tag(NewFrame(holder, zIdx+1))
    cf.BackgroundColor3 = COL.goldMid
    cf.Size = UDim2.new(0, sw*0.28, 0, sh*1.02)
    cf.AnchorPoint = Vector2.new(0.5,1)
    cf.Position = UDim2.new(0.5,0,1,0)
    cf.Rotation = lean

    local rf = tag(NewFrame(holder, zIdx))
    rf.BackgroundColor3 = COL.goldBright
    rf.Size = UDim2.new(0, sw*0.68, 0, sh*1.08)
    rf.AnchorPoint = Vector2.new(0,1)
    rf.Position = UDim2.new(0.5, -sw*0.10, 1, 0)
    rf.Rotation = lean + 11

    local apex = tag(NewFrame(holder, zIdx+2))
    apex.BackgroundColor3 = COL.goldBright
    apex.Size = UDim2.new(0,3,0,3)
    apex.AnchorPoint = Vector2.new(0.5,0.5)
    local tipX = 0.5 + (math.sin(math.rad(lean))*sh*0.5)/holderW
    local tipY = 1 - (sh*0.98)/holderH
    apex.Position = UDim2.new(tipX,0, tipY,0)
    local uc = Instance.new("UICorner")
    uc.CornerRadius = UDim.new(1,0)
    uc.Parent = apex
    return holder
end

