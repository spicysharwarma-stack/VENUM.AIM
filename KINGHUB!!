-- HELPERS
local function Tween(obj, goal, t, style, dir, delay)
    local ti = TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out, 0, false, delay or 0)
    local tw = TweenService:Create(obj, ti, goal)
    tw:Play()
    return tw
end
local function Rand(a, b) return a + math.random() * (b - a) end
local function PlaySound(id, vol, pitch)
    local s = Instance.new("Sound")
    s.SoundId = id
    s.Volume = vol or 0.7
    s.PlaybackSpeed = pitch or 1.0
    s.Parent = SoundService
    s:Play()
    Debris:AddItem(s, 8)
end

