        -- Wall modification functions
        local function processPart(obj)
            if obj:IsA("BasePart") then
                originalWallProperties[obj] = {
                    Color = obj.Color,
                    Transparency = obj.Transparency,
                    CanCollide = obj.CanCollide
                }
                local rainbowLoop = task.spawn(function()
                    while wallsModified and obj and obj.Parent do
                        for i = 0, 1, 0.01 do
                            if not wallsModified then break end
                            obj.Color = Color3.fromHSV(i, 1, 1)
                            task.wait(0.02)
                        end
                    end
                end)
                rainbowLoops[obj] = rainbowLoop
                obj.Transparency = 0.5
                obj.CanCollide = false
            end
        end

        local function recursiveProcess(obj)
            processPart(obj)
            for _, child in ipairs(obj:GetChildren()) do
                recursiveProcess(child)
            end
        end

        local function restoreWalls()
            for obj, properties in pairs(originalWallProperties) do
                if obj and obj.Parent then
                    obj.Color = properties.Color
                    obj.Transparency = properties.Transparency
                    obj.CanCollide = properties.CanCollide
                    if rainbowLoops[obj] then
                        task.cancel(rainbowLoops[obj])
                        rainbowLoops[obj] = nil
                    end
                end
            end
            originalWallProperties = {}
            rainbowLoops = {}
            wallsModified = false
        end

        local function modifyWalls()
            if wallsModified then
                restoreWalls()
                return "OFF"
            end
            wallsModified = true
            for _, v in pairs(workspace:FindFirstChild("Prison_OuterWall") and workspace.Prison_OuterWall:FindFirstChild("prison_wall") and workspace.Prison_OuterWall.prison_wall:GetChildren() or {}) do
                recursiveProcess(v)
            end
            for _, v in pairs(workspace:FindFirstChild("Prison_guardtower") and workspace.Prison_guardtower:GetChildren() or {}) do
                recursiveProcess(v)
            end
            for _, v in pairs(workspace:FindFirstChild("Prison_Fences") and workspace.Prison_Fences:GetChildren() or {}) do
                if v.Name == "fence" then
                    recursiveProcess(v)
                    local dmg = v:FindFirstChild("damagePart")
                    if dmg then
                        local ti = dmg:FindFirstChild("TouchInterest")
                        if ti then ti:Destroy() end
                    end
                end
            end
            local doors = workspace:FindFirstChild("Doors")
            if doors then
                for _, door in pairs(doors:GetChildren()) do
                    recursiveProcess(door)
                end
            end
            return "ON"
        end

