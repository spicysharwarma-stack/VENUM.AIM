        controls.keybindsToggle = CreateToggleButton("Keybinds Active", velocityEnabled, function(state)
            velocityEnabled = state
        end)
        
        -- Acceleration Multiplier Dragger
        controls.accelMult = CreateDraggerSlider("Accel Multiplier", 0, 0.05, velocityMult, function(value)
            velocityMult = value
        end)
        
        -- Brake Force Dragger (Q Keybind)
        controls.brakeForce = CreateDraggerSlider("Brake Force (Q)", 0, 3.0, velocityMult2, function(value)
            velocityMult2 = value
        end)
        
        -- Disable Body Collision Button (EXACTLY like first script)
        CreateTextButton("Disable Body Collision: " .. (collisionDisabled and "ON" or "OFF"), function()
            local result = ToggleCollision()
            -- Update all buttons to show correct state
            for _, child in ipairs(ContentFrame:GetChildren()) do
                if child:IsA("TextButton") and child.Text:find("Disable Body Collision") then
                    child.Text = "Disable Body Collision: " .. (result and "ON" or "OFF")
                    break
                end
            end
        end)
        
        -- Stop Vehicle Button
        CreateTextButton("Stop Vehicle (P)", function()
            local Character = player.Character
            if Character and typeof(Character) == "Instance" then
                local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
                if Humanoid and typeof(Humanoid) == "Instance" then
                    local SeatPart = Humanoid.SeatPart
                    if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                        SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end)
        
        -- Rear Wheel Friction (FIXED: 0.2 friction, 54 weight)
        CreateTextButton("Rear Wheel Friction: " .. (rearWheelModified and "ON" or "OFF"), function()
            local result = ModifyRearWheels()
            -- Update all buttons to show correct state
            for _, child in ipairs(ContentFrame:GetChildren()) do
                if child:IsA("TextButton") and child.Text:find("Rear Wheel Friction") then
                    child.Text = "Rear Wheel Friction: " .. (result and "ON" or "OFF")
                    break
                end
            end
        end)
        
        -- Springs Visibility
        CreateTextButton("Springs Visibility", function()
            local visible = ToggleSpringsVisibility()
            -- Update all buttons to show correct state
            for _, child in ipairs(ContentFrame:GetChildren()) do
                if child:IsA("TextButton") and child.Text:find("Springs") then
                    child.Text = "Springs: " .. (visible and "VISIBLE" or "HIDDEN")
                    break
                end
            end
        end)
        
    elseif CurrentTab == "Flight" then
        -- Flight Toggle
        controls.flightToggle = CreateToggleButton("Flight Mode", flightEnabled, function(state)
            flightEnabled = state
        end)
        
        -- Flight Speed Dragger (UPDATED: from 0-8 to 0-800 divided by 100, like Venyx script)
        controls.flightSpeed = CreateDraggerSlider("Flight Speed", 0, 800, flightSpeed * 100, function(value)
            flightSpeed = value / 100
        end)
        
    elseif CurrentTab == "Wheels" then
        -- Wheel Increment Dragger (Max 5)
        controls.wheelInc = CreateDraggerSlider("Wheel Increment", 0.1, 5.0, wheelIncrement, function(value)
            wheelIncrement = value
        end)
        
        -- Wheel Controls
        CreateTextButton("Lower All Wheels", function()
            ModifyAllWheels(1)
        end)
        
        CreateTextButton("Raise All Wheels", function()
            ModifyAllWheels(-1)
        end)
        
        CreateTextButton("Lower Front Wheels", function()
