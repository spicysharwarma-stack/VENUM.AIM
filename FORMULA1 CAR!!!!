    toggleButton.Parent = toggleFrame
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 8)
    buttonCorner.Parent = toggleButton
    
    local function updateState(state)
        initialState = state
        toggleButton.Text = text .. ": " .. (state and "ON" or "OFF")
        toggleButton.TextColor3 = state and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    end
    
    toggleButton.MouseEnter:Connect(function()
        TweenService:Create(toggleButton, TweenInfo.new(0.3), {
            BackgroundTransparency = 0.1,
            BackgroundColor3 = Color3.fromRGB(45, 40, 55)
        }):Play()
    end)
    
    toggleButton.MouseLeave:Connect(function()
        TweenService:Create(toggleButton, TweenInfo.new(0.3), {
            BackgroundTransparency = 0.2,
            BackgroundColor3 = Color3.fromRGB(35, 30, 45)
        }):Play()
    end)
    
    toggleButton.MouseButton1Click:Connect(function()
        local newState = not initialState
        updateState(newState)
        
        TweenService:Create(toggleButton, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.fromRGB(212, 175, 55),
            TextColor3 = Color3.fromRGB(20, 15, 25)
        }):Play()
        wait(0.1)
        TweenService:Create(toggleButton, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(35, 30, 45),
            TextColor3 = newState and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        }):Play()
        
        pcall(callback, newState)
    end)
    
    return {update = updateState, currentState = function() return initialState end}
end

function CreateTextButton(text, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 32)
    button.BackgroundColor3 = Color3.fromRGB(35, 30, 45)
    button.BackgroundTransparency = 0.2
    button.Text = text
    button.TextColor3 = Color3.fromRGB(240, 230, 255)
    button.Font = Enum.Font.GothamMedium
    button.TextSize = 12
    button.AutoButtonColor = false
    button.ZIndex = 11
    button.Parent = ContentFrame
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 8)
    buttonCorner.Parent = button
    
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.3), {
            BackgroundTransparency = 0.1,
            BackgroundColor3 = Color3.fromRGB(45, 40, 55)
        }):Play()
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.3), {
            BackgroundTransparency = 0.2,
            BackgroundColor3 = Color3.fromRGB(35, 30, 45)
        }):Play()
    end)
    
    button.MouseButton1Click:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.fromRGB(212, 175, 55),
            TextColor3 = Color3.fromRGB(20, 15, 25)
        }):Play()
        wait(0.1)
        TweenService:Create(button, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(35, 30, 45),
            TextColor3 = Color3.fromRGB(240, 230, 255)
        }):Play()
        
        pcall(callback)
    end)
    
    return button
end

