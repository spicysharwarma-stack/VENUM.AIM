        CreateTextButton("Raise Front Wheels", function()
            ModifyWheelHeight("Front", -1)
        end)
        
        CreateTextButton("Lower Rear Wheels", function()
            ModifyWheelHeight("Rear", 1)
        end)
        
        CreateTextButton("Raise Rear Wheels", function()
            ModifyWheelHeight("Rear", -1)
        end)
    end
end

