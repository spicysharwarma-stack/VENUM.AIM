-- Create Dragger Slider Function
function CreateDraggerSlider(text, minValue, maxValue, currentValue, callback)
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 40)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.ZIndex = 11
    sliderFrame.Parent = ContentFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 15)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. string.format("%.3f", currentValue)
    label.TextColor3 = Color3.fromRGB(240, 230, 255)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 11
    label.Parent = sliderFrame
    
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 20)
    track.BackgroundColor3 = Color3.fromRGB(45, 40, 55)
    track.BorderSizePixel = 0
    track.ZIndex = 11
    track.Parent = sliderFrame
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(1, 0)
    trackCorner.Parent = track
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((currentValue - minValue) / (maxValue - minValue), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
    fill.BorderSizePixel = 0
    fill.ZIndex = 12
    fill.Parent = track
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fill
    
    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 12, 0, 12)
    thumb.Position = UDim2.new((currentValue - minValue) / (maxValue - minValue), -6, 0.5, -6)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 13
    thumb.Parent = track
    
    local thumbCorner = Instance.new("UICorner")
    thumbCorner.CornerRadius = UDim.new(1, 0)
    thumbCorner.Parent = thumb
    
    local dragging = false
    
    local function updateValue(value)
        local newValue = math.clamp(value, minValue, maxValue)
        currentValue = newValue
        label.Text = text .. ": " .. string.format("%.3f", newValue)
        fill.Size = UDim2.new((newValue - minValue) / (maxValue - minValue), 0, 1, 0)
        thumb.Position = UDim2.new((newValue - minValue) / (maxValue - minValue), -6, 0.5, -6)
        pcall(callback, newValue)
    end
    
    local function onInputChanged(input)
        if dragging then
            local relativeX = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local value = minValue + (relativeX * (maxValue - minValue))
            updateValue(value)
        end
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            onInputChanged(input)
        end
    end)
    
    track.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            onInputChanged(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return {
        update = function(value)
            updateValue(value)
        end,
        getValue = function()
            return currentValue
        end
    }
end

