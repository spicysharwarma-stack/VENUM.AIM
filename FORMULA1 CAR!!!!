-- Vehicle Functions
local function GetVehicleFromDescendant(Descendant)
    return
        Descendant:FindFirstAncestor(player.Name .. "\'s Car") or
        (Descendant:FindFirstAncestor("Body") and Descendant:FindFirstAncestor("Body").Parent) or
        (Descendant:FindFirstAncestor("Misc") and Descendant:FindFirstAncestor("Misc").Parent) or
        Descendant:FindFirstAncestorWhichIsA("Model")
end

local function RefreshSelectedCar()
    selectedcar = nil
    for i,v in pairs(cars:GetDescendants()) do
        if v:IsA("Weld") and v.Part1 and v.Part1.Parent and v.Part1.Parent.Name == player.Name then
            selectedcar = v.Parent.Parent.Parent
            break
        end
    end
    
    if selectedcar ~= nil then
        print("[Crown Hub] Selected Car: "..selectedcar.Name)
    else
        print("[Crown Hub] No car selected")
    end
    
    return selectedcar
end

-- Collision Disable Function (EXACTLY like first script - Body only)
local function ToggleCollision()
    if not selectedcar then
        print("[Crown Hub] No car selected for collision toggle")
        return false
    end
    
    if not collisionDisabled then
        -- Disable collision for ALL parts in Body folder (exactly like first script)
        local BodyFolder = selectedcar:FindFirstChild("Body")
        if BodyFolder then
            for _, v in pairs(BodyFolder:GetDescendants()) do
                if v:IsA("BasePart") then
                    originalCollisionStates[v] = v.CanCollide
                    v.CanCollide = false
                    print("[Crown Hub] Disabled collision for: "..v.Name)
                end
            end
            collisionDisabled = true
            print("[Crown Hub] Collision DISABLED for Body parts")
            return true
        else
            print("[Crown Hub] No Body folder found in selected car")
            return false
        end
    else
        -- Restore original collision states
        for part, canCollide in pairs(originalCollisionStates) do
            if part and part.Parent then
                part.CanCollide = canCollide
            end
        end
        originalCollisionStates = {}
        collisionDisabled = false
        print("[Crown Hub] Collision RESTORED for Body parts")
        return false
    end
end

-- UPDATED: Better Flight System from Venyx Script
RunService.Stepped:Connect(function()
    local Character = player.Character
    if flightEnabled == true then
        if Character and typeof(Character) == "Instance" then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and typeof(Humanoid) == "Instance" then
                local SeatPart = Humanoid.SeatPart
                if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                    local Vehicle = GetVehicleFromDescendant(SeatPart)
                    if Vehicle and Vehicle:IsA("Model") then
                        Character.Parent = Vehicle
                        if not Vehicle.PrimaryPart then
                            if SeatPart.Parent == Vehicle then
                                Vehicle.PrimaryPart = SeatPart
                            else
                                Vehicle.PrimaryPart = Vehicle:FindFirstChildWhichIsA("BasePart")
                            end
                        end
                        local PrimaryPartCFrame = Vehicle:GetPrimaryPartCFrame()
                        Vehicle:SetPrimaryPartCFrame(CFrame.new(PrimaryPartCFrame.Position, PrimaryPartCFrame.Position + workspace.CurrentCamera.CFrame.LookVector) * (UserInputService:GetFocusedTextBox() and CFrame.new(0, 0, 0) or CFrame.new((UserInputService:IsKeyDown(Enum.KeyCode.D) and flightSpeed) or (UserInputService:IsKeyDown(Enum.KeyCode.A) and -flightSpeed) or 0, (UserInputService:IsKeyDown(Enum.KeyCode.E) and flightSpeed / 2) or (UserInputService:IsKeyDown(Enum.KeyCode.Q) and -flightSpeed / 2) or 0, (UserInputService:IsKeyDown(Enum.KeyCode.S) and flightSpeed) or (UserInputService:IsKeyDown(Enum.KeyCode.W) and -flightSpeed) or 0)))
                        SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end
    else
        if Character and typeof(Character) == "Instance" then
            Character.Parent = defaultCharacterParent or Character.Parent
            defaultCharacterParent = Character.Parent
        end
    end
end)

-- Input Handling
local accelerationActive = false
local brakeActive = false

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    
    if input.KeyCode == velocityEnabledKeyCode and velocityEnabled then
        accelerationActive = true
        spawn(function()
            while accelerationActive and velocityEnabled do
                task.wait()
                local Character = player.Character
                if Character and typeof(Character) == "Instance" then
                    local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
                    if Humanoid and typeof(Humanoid) == "Instance" then
                        local SeatPart = Humanoid.SeatPart
                        if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                            SeatPart.AssemblyLinearVelocity = SeatPart.AssemblyLinearVelocity * Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
                        end
                    end
                end
            end
        end)
    end
    
    if input.KeyCode == qbEnabledKeyCode and velocityEnabled then
        brakeActive = true
        spawn(function()
            while brakeActive and velocityEnabled do
                task.wait()
                local Character = player.Character
                if Character and typeof(Character) == "Instance" then
                    local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
                    if Humanoid and typeof(Humanoid) == "Instance" then
                        local SeatPart = Humanoid.SeatPart
                        if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                            SeatPart.AssemblyLinearVelocity = SeatPart.AssemblyLinearVelocity * Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
                        end
                    end
                end
            end
        end)
    end
    
    if input.KeyCode == Enum.KeyCode.P and velocityEnabled then
        local Character = player.Character
        if Character and typeof(Character) == "Instance" then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and typeof(Humanoid) == "Instance" then
                local SeatPart = Humanoid.SeatPart
                if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                    SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    
    if input.KeyCode == velocityEnabledKeyCode then
        accelerationActive = false
    end
    
    if input.KeyCode == qbEnabledKeyCode then
        brakeActive = false
    end
end)

-- Wheel Modification Functions (FIXED: 0.2 friction, 54 weight)
local function ModifyRearWheels()
    if not selectedcar then
        print("[Crown Hub] No car selected for rear wheel mod")
        return false
    end
    
    if not rearWheelModified then
        print("[Crown Hub] Applying rear wheel friction: 0.2 friction, 54 weight")
        
        -- Find and modify rear wheels
        for _, part in pairs(selectedcar:GetDescendants()) do
            if part:IsA("BasePart") then
                local partName = part.Name:lower()
                if partName:find("rear") or partName:find("back") or partName:find("rwd") then
                    -- Store original properties
                    originalFrictions[part] = {
                        Friction = part.Friction,
                        FrictionWeight = part.FrictionWeight
                    }
                    
                    -- Apply FIXED values
                    part.Friction = 0.2
                    part.FrictionWeight = 54
                    print("[Crown Hub] Modified: "..part.Name.." to Friction=0.2, Weight=54")
                end
            end
        end
        rearWheelModified = true
    else
        print("[Crown Hub] Restoring original rear wheel friction")
        
        -- Restore original properties
        for part, props in pairs(originalFrictions) do
            if part and part.Parent then
                part.Friction = props.Friction
                part.FrictionWeight = props.FrictionWeight
                print("[Crown Hub] Restored: "..part.Name)
            end
        end
        originalFrictions = {}
        rearWheelModified = false
    end
    
    return rearWheelModified
end

local function ModifyWheelHeight(wheelType, direction)
    if not selectedcar then return end
    
    local wheelNames = {
        ["Front"] = {"front", "fw", "frontwheel", "lw", "rw", "vs", "ss"},
        ["Rear"] = {"rear", "back", "rw", "rearwheel", "rwd"}
    }
    
    local names = wheelNames[wheelType]
    if not names then return end
    
    for _, part in pairs(selectedcar:GetDescendants()) do
        if part:IsA("BasePart") then
            local partName = part.Name:lower()
            for _, name in ipairs(names) do
                if partName:find(name) then
                    part.Position = part.Position + Vector3.new(0, direction * wheelIncrement, 0)
                    break
                end
            end
        end
    end
end

local function ModifyAllWheels(direction)
    if not selectedcar then return end
    
    for _, part in pairs(selectedcar:GetDescendants()) do
        if part:IsA("BasePart") and (part.Name:lower():find("wheel") or part.Name:lower():find("tire") or part.Name:lower():find("wd") or part.Name:lower():find("vs") or part.Name:lower():find("ss")) then
            part.Position = part.Position + Vector3.new(0, direction * wheelIncrement, 0)
        end
    end
end

local function ToggleSpringsVisibility()
    if not selectedcar then return false end
    
    local anySpring = nil
    for _, SpringConstraint in pairs(selectedcar:GetDescendants()) do
        if SpringConstraint:IsA("SpringConstraint") then
            anySpring = SpringConstraint
            break
        end
    end
    
    if anySpring then
        local newVisibility = not anySpring.Visible
        for _, SpringConstraint in pairs(selectedcar:GetDescendants()) do
            if SpringConstraint:IsA("SpringConstraint") then
                SpringConstraint.Visible = newVisibility
            end
        end
        return newVisibility
    end
    
    return false
end

